# =============================================================================
# PostgreSQL Configuration
# =============================================================================
POSTGRES_USER=odoo_auditor
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=odoo_auditor
# DATABASE_URL is auto-generated from the above:
# postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# =============================================================================
# Security Keys (REQUIRED - generate unique values for production)
# =============================================================================
# Generate Fernet key:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=<your-fernet-key-here>

# Generate JWT secret:
# openssl rand -hex 32
JWT_SECRET_KEY=<your-jwt-secret-key-here>

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# =============================================================================
# Application Configuration
# =============================================================================
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# =============================================================================
# CORS Configuration (comma-separated origins)
# =============================================================================
FRONTEND_URLS=http://localhost:80,http://localhost:3000